NODE_ENV="development"

# LLM providers
ANTHROPIC_API_KEY=""

# Skills
TAVILY_API_KEY=""

# Google OAuth (Cloud Console → APIs & Services → Credentials → OAuth client of type Web).
# Authorized redirect URI in dev: http://localhost:<edge.devPort>/api/skills/oauth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# DynamoDB table-name prefix (CDK-injected in prod). Each repo derives
# `${prefix}-<entity>`, e.g. "<prefix>-users".
TABLE_NAME_PREFIX=""

# Agent state storage (CDK-injected)
AGENT_STORAGE_BUCKET=""

# Optional: realtime (AWS IoT MQTT)
AGENT_MQTT_BROKER_URL=""
AGENT_MQTT_NAMESPACE="serverless-agent-dev"

# Optional: observability
# POSTHOG_KEY=""
# POSTHOG_HOST="https://us.i.posthog.com"
# AXIOM_API_TOKEN=""
# AXIOM_DATASET=""
